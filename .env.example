# 复制为 .env

# Postgres（本地 Docker）：docker compose up -d 后使用下行
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/projecthub"

# 公网（Neon / Supabase 等）示例：
# DATABASE_URL="postgresql://用户:密码@host/dbname?sslmode=require"

JWT_SECRET="replace-with-long-random-string-in-production-min-32-chars"

# 浏览器/API 生成的绝对链接（登录重定向、OG 等）；生产改成 https://你的域名
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenRouter — 任务「AI 文本分析」（可选）
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
