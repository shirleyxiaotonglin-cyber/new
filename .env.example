# 复制为 .env

# —— 本地 Docker（与 DIRECT_URL 可填成相同） ——
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/projecthub"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/projecthub"

# —— Supabase（https://supabase.com/dashboard → 选项目 → Project Settings） ——
# 1) Settings → Database
# 2) "Connection string"：选 URI，密码在 "Database password" 若忘记可 Reset
# 3) 应用用「连接池 / Session / Transaction」时，Prisma 需要两个地址：
#
#    DATABASE_URL  = 带 PgBouncer/Pool 的地址（Vercel/Serverless 推荐，例 :6543 或 pooler 主机加 ?pgbouncer=true）
#    DIRECT_URL    = 直连数据库，用于 prisma migrate（例 主机 :5432、无 pgbouncer）
#
# 若在本地只直连、不用池化，两行可写成一模一样的连接串。
#
# DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-xx.pooler.supabase.com:5432/postgres"
#
# Neon（Vercel）：DATABASE_URL 用「Pooled」串（主机名常含 pooler）；DIRECT_URL 必须用「Direct」串，
# 勿把 Pooler 填进 DIRECT_URL，否则 prisma migrate deploy 可能 P1002 / advisory lock 超时。

JWT_SECRET="replace-with-long-random-string-in-production-min-32-chars"

# 浏览器/API 绝对链接（重置密码邮件、跳转）；生产改为 https://你的域名
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 登录页「一键演示」：默认开启。若需在正式站关闭演示一键登录接口，设为 true 并 Redeploy
# DISABLE_DEMO_LOGIN=true

# —— 可选：仅在要用 Supabase 客户端（Realtime 等）时配置 ——
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# 忘记密码邮件（Resend）
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=ProjectHub <onboarding@你的域名>

# Supabase Storage — 任务交付物（可选；未配置则无法上传文件）
# 浏览器直传到 Storage + 数据库记绑定；勿依赖「经 Next API 上传大文件」（Vercel 等对函数请求体约 4.5MB）。
# 控制台创建项目 → Storage → New bucket，名称与下方一致（默认 deliverables），设为 Private。
# Settings → API：Project URL + service_role（仅服务端，勿暴露给浏览器）
# SUPABASE_URL="https://xxxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."
# SUPABASE_STORAGE_BUCKET=deliverables

# OpenRouter — AI 任务分析（可选）https://openrouter.ai/keys
# 本机 .env；Vercel 在 Environment Variables 填同名，并 Redeploy
# 扣费在 OpenRouter 账户余额；与「在其它产品里给 DeepSeek 直接付费」是不同渠道，需用 OpenRouter 的 key 与模型 slug。
# OPENROUTER_API_KEY=sk-or-v1-...
# 例：DeepSeek V3.2（OpenRouter 官方 id，见 https://openrouter.ai/deepseek/deepseek-v3.2 ）
# OPENROUTER_MODEL=deepseek/deepseek-v3.2
# 未指定时服务端默认 openai/gpt-4o-mini（与下方示例二选一即可）
# OPENROUTER_MODEL=openai/gpt-4o-mini
# 服务端等待 OpenRouter 的最长时间（毫秒）；默认 45000，适用于任务解析、工作报告、计划表、PRD 建议等。
# OPENROUTER_ANALYZE_TIMEOUT_MS=45000
# 若不使用 ANALYZE 变量名，也可用（二选一即可，ANALYZE 优先）
# OPENROUTER_REQUEST_TIMEOUT_MS=45000
# 若默认模型返回 403（上游 ToS / 审核），可设备用模型，首次 403 会自动重试一次：
# OPENROUTER_FALLBACK_MODEL=google/gemma-2-9b-it
# 服务端请求会带 HTTP-Referer（默认 NEXT_PUBLIC_APP_URL，否则 localhost）；与浏览器里别的站不一致时可显式指定：
# OPENROUTER_HTTP_REFERER=https://你的生产域名
# OPENROUTER_APP_TITLE=ProjectHub
# 调试：不向 OpenRouter 发送 Referer / X-Title（慎用）
# OPENROUTER_OMIT_ATTRIBUTION=0
