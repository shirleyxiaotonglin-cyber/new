{
  "name": "cursor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "ensure-dev": "node scripts/ensure-dev.mjs",
    "predev": "node scripts/ensure-dev.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "start": "next start -p 3000",
    "lint": "next lint",
    "clean": "rm -rf .next",
    "recover": "node scripts/recover.mjs",
    "docker:db": "docker compose up -d",
    "dev:clean": "npm run clean && npm run dev",
    "static:serve": "npx --yes serve static-site -l 5500",
    "static:sync": "node scripts/sync-static-site.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "5.22.0",
    "@supabase/supabase-js": "^2.103.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.9",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
